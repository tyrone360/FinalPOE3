<Window x:Class="demo.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:demo"
        mc:Ignorable="d"
        Title="MainWindow" Height="450" Width="800">
    <Grid>

        <!-- 
            HOME GRID
            This grid serves as the main landing page  of the application.
            It contains a logo for AI , a welcome message to greet users,
            and a navigation button to proceed to the next section.
            Currently hidden by default.
        -->
        <Grid x:Name="home_grid" Visibility="Visible">
            
            <!-- Logo -->
            <Image 
                Source="/logo.png" 
                Height="200"
                Width="300"
                Margin="0,0,0,200"
                   />
<!-- welcome message-->
			<TextBlock
    Text="Welcome To TYRONE AI"
    Height="40"
    Width="350"
    TextAlignment="Center"
    Margin="0,20,0,0"
    FontSize="28"
    FontWeight="Bold"
    Foreground="#06B6D4"
    FontFamily="Segoe UI"/>
            
            <!-- button to continue-->
			<Button
    Height="55"
    Width="320"
    Margin="0,220,0,0"
    Content=" Get Started"
    Click="proceed"
    Background="#2563EB"
    Foreground="White"
    FontSize="16"
    FontWeight="Bold"
    FontFamily="Segoe UI"
    BorderThickness="0"
    Cursor="Hand"/>

        </Grid>

        <!-- 
            USERNAME GRID
            This grid is for prompting the user for username.
            It contains a logo for AI, a textbox for users to enter their name,
            and a submit button to save the username.
            Hidden .
        -->
        <Grid x:Name="username_grid" Visibility="Hidden">


            <!-- Logo -->
            <Image 
                Source="/logo.png" 
                Height="200"
                Width="300"
                Margin="0,0,0,200"
                   />
            <!-- Hint message-->
			<TextBlock
		Text=" Create Your AI Profile"
		Height="35"
		Width="350"
		TextAlignment="Center"
		Margin="0,30,0,0"
		FontSize="22"
		FontWeight="Bold"
		Foreground="White"
		FontFamily="Segoe UI"/>
            
            <!-- Enter/Prompt username-->
			<TextBox
    x:Name="usernames_input"
    Height="50"
    Width="350"
    Margin="0,120,0,0"
    FontSize="15"
    FontFamily="Segoe UI"
    FontWeight="SemiBold"
    Foreground="White"
    Background="#1E293B"
    BorderBrush="#06B6D4"
    BorderThickness="2"
    TextAlignment="Center"
    VerticalContentAlignment="Center"
    ToolTip="Enter your username"/>

            <!-- error message-->
			<TextBlock
	 x:Name="UsernameErrorText"
	 Text=" Username required to continue"
	 Height="30"
	 Width="350"
	 TextAlignment="Center"
	 Margin="0,190,0,0"
	 Foreground="#EF4444"
	 FontSize="13"
	 FontWeight="SemiBold"
	 FontFamily="Segoe UI"
	 Visibility="Hidden"/>

            <!-- button to submit name-->
			<Button
    Height="55"
    Width="320"
    Margin="0,260,0,0"
    Content=" Start AI Experience"
    Click="submit_name"
    Background="#2563EB"
    Foreground="White"
    FontSize="16"
    FontWeight="Bold"
    FontFamily="Segoe UI"
    BorderThickness="0"
    Cursor="Hand"/>

        </Grid>

        <!-- 
            CHAT GRID
            This grid handles all messaging and conversation-related features of the application.
            It contains a ListView to display chat messages, a textbox for typing questions,
            and a submit button to send the question to the chat.
            Starting in a hidden state.
        -->

        <!-- Main application page, initially hidden -->
		<Grid>

			<Grid.ColumnDefinitions>
				<ColumnDefinition Width="*" />
				<ColumnDefinition Width="190" />
			</Grid.ColumnDefinitions>

			<!-- MAIN CONTENT (game / chat / quiz) -->
			<Grid Grid.Column="0">
				<!-- your main UI goes here -->
			

                <!-- StackPanel containing menu buttons -->
				<StackPanel Grid.Column="1"
			   Background="#1E293B"
			   Width="190">

					<TextBlock Text="TYRONE AI"
							   FontSize="22"
							   FontWeight="Bold"
							   Foreground="White"
							   TextAlignment="Center"
							   Margin="0,20,0,5"/>

					<TextBlock Text="AI Assistant"
							   FontSize="11"
							   Foreground="#CBD5E1"
							   TextAlignment="Center"
							   Margin="0,0,0,25"/>

					<!-- Buttons -->
					<Button Content="Chats"
							Margin="0,5"
							Height="45"
							Click="chatting"
							Background="#2563EB"
							Foreground="White"
							FontWeight="Bold"
							BorderThickness="0"/>

					<Button Content="Tasks Reminders"
							Margin="0,5"
							Height="45"
							Click="reminders"
							Background="#10B981"
							Foreground="White"
							FontWeight="Bold"
							BorderThickness="0"/>

					<Button Content="Activity Log"
							Margin="0,5"
							Height="45"
							Click="activity"
							Background="#F59E0B"
							Foreground="White"
							FontWeight="Bold"
							BorderThickness="0"/>

					<Button Content="Game"
							Margin="0,20,0,0"
							Height="45"
							Click="game"
							Background="#8B5CF6"
							Foreground="White"
							FontWeight="Bold"
							BorderThickness="0"/>

					<Button Content="Exit"
							Margin="0,20,0,0"
							Height="45"
							Click="exit"
							Background="#EF4444"
							Foreground="White"
							FontWeight="Bold"
							BorderThickness="0"/>

				</StackPanel>
            </Grid>

            
            
            
            
            
            
            
            
            
            
            <!-- Chat page - default visible inside main app -->
			<Grid Margin="0,0,205,0"
		   x:Name="chat_page"
		   Visibility="Visible"
		   Background="#0F172A">

                <!-- ListView to show chat messages -->
				<ListView Margin="20,10,27,101"
          x:Name="chats"
          Background="#1E293B"
          Foreground="White"
          BorderBrush="#334155"
          BorderThickness="1"
          FontSize="14"
          FontFamily="Segoe UI"/>

                <!-- TextBox to type user's questions -->
				<TextBox Margin="20,356,158,44"
		  x:Name="question"
		  Height="50"
		  Background="#334155"
		  Foreground="White"
		  BorderBrush="#06B6D4"
		  BorderThickness="2"
		  FontSize="14"
		  FontFamily="Segoe UI"
		  VerticalContentAlignment="Center"/>

                <!-- Button to submit user's question -->
				<Button Content=" Send"
        Click="send"
        Height="50"
        Margin="442,357,27,43"
        Background="#2563EB"
        Style="{StaticResource ModernButton}"/>
            </Grid>

            
            
            
            
            
            
            
            
            
            
            
            
            
            
            
            <!-- Reminders page -->
            <Grid Margin="0,0,205,0"
            x:Name="reminderPage"
            Visibility="Hidden">

                <!-- ListView showing reminders, double-click to mark done or delete -->
                <ListView Margin="20,10,27,87"
                    MouseDoubleClick="remind_append_MouseDoubleClick"
                    x:Name="view_tasks" />

                <!-- Instructions for reminders page -->
				<!-- Instructions for reminders page -->
				<TextBlock Grid.Row="2"
						   Text="All tasks will be listed above with their status (done or due). Double-click to mark as done, and double-click again to delete once completed."
						   TextAlignment="Center"
						   TextWrapping="Wrap"
						   Foreground="#FF4D4D"
						   FontSize="12"
						   Margin="20"
						   Opacity="0.9"/>
            </Grid>

            
            
            
            
            
            
            
            
            
            <!-- History page -->
            <Grid Margin="0,0,205,0"
            x:Name="HistoryPage"
            Visibility="Hidden">

                <!-- ListView to show user's interest history -->
                <ListView Margin="20,10,27,87"
                    MouseDoubleClick="remind_append_MouseDoubleClick"
                    x:Name="history_append" />

                <!-- Instructions for history page -->
				<!-- Instructions for history page -->
				<TextBlock Grid.Row="2"
						   Text="If no history is listed, add some from chats by saying: 'I'm interested in...' then mention your interest. Thank you."
						   TextAlignment="Center"
						   TextWrapping="Wrap"
						   Foreground="#FF4D4D"
						   FontSize="12"
						   Margin="20"
						   Opacity="0.9"/>
            </Grid>

            <!-- Activity log page -->
            <Grid Margin="0,0,205,0"
            x:Name="LogPage"
            Visibility="Hidden">

                <!-- ListView showing all app activities -->
                <ListView Margin="20,10,27,87"
                    MouseDoubleClick="remind_append_MouseDoubleClick"
                    x:Name="log_append" />

                <!-- Instructions for activity log -->
				<!-- Activities / Info Text -->
				<TextBlock Grid.Row="2"
						   Text="All activities in the app will be shown here based on what you do."
						   TextAlignment="Center"
						   TextWrapping="Wrap"
						   Foreground="#FF4D4D"
						   FontSize="12"
						   Margin="20"
						   Opacity="0.9"/>
            </Grid>

            <!-- Game page for quiz -->
            <Grid Margin="0,0,205,0"
            x:Name="gamePage"
            Visibility="Hidden">

                <!-- Quiz game content -->
                <Grid Height="390px"
                x:Name="quizGame_page"
                Visibility="Visible"
                Margin="10,30,10,30">

                    <!-- Question text -->
					<!-- Question text -->
					<TextBlock Height="50"
							   Width="300"
							   Text="Question"
							   Foreground="SkyBlue"
							   TextAlignment="Center"
							   FontSize="20"
							   x:Name="question_asked"
							   Margin="0,0,0,20"
							   HorizontalAlignment="Center"
							   VerticalAlignment="Top"/>

                    <!-- Four option buttons for answers -->
					<!-- Quiz Options (compact + no overlap) -->
					<Grid HorizontalAlignment="Center"
						  VerticalAlignment="Center"
						  Margin="0,40,0,0">

						<Grid.RowDefinitions>
							<RowDefinition Height="Auto"/>
							<RowDefinition Height="Auto"/>
						</Grid.RowDefinitions>

						<Grid.ColumnDefinitions>
							<ColumnDefinition Width="Auto"/>
							<ColumnDefinition Width="Auto"/>
						</Grid.ColumnDefinitions>

						<!-- Option 1 -->
						<Button x:Name="optionButtonOne"
								Content="Option 1"
								Width="160"
								Height="35"
								Margin="6"
								Background="#3A3A3A"
								Foreground="White"
								FontSize="11"
								Click="optionSelected"/>

						<!-- Option 2 -->
						<Button x:Name="optionButtonTwo"
								Content="Option 2"
								Width="160"
								Height="35"
								Margin="6"
								Background="#3A3A3A"
								Foreground="White"
								FontSize="11"
								Grid.Column="1"
								Click="optionSelected"/>

						<!-- Option 3 -->
						<Button x:Name="optionButtonThree"
								Content="Option 3"
								Width="160"
								Height="35"
								Margin="6"
								Background="#3A3A3A"
								Foreground="White"
								FontSize="11"
								Grid.Row="1"
								Click="optionSelected"/>

						<!-- Option 4 -->
						<Button x:Name="optionButtonFour"
								Content="Option 4"
								Width="160"
								Height="35"
								Margin="6"
								Background="#3A3A3A"
								Foreground="White"
								FontSize="11"
								Grid.Row="1"
								Grid.Column="1"
								Click="optionSelected"/>

					</Grid>

					<!-- ANSWER BUTTON -->
					<Button x:Name="answerButton"
							Content="Answer"
							Width="120"
							Height="45"
							Background="#FF3B3B"
							Foreground="White"
							FontWeight="Bold"
							HorizontalAlignment="Center"
							VerticalAlignment="Bottom"
							Margin="0,0,0,120"
							Click="answerButton"/>

					<!-- SCORE DISPLAY -->
					<Border HorizontalAlignment="Left"
							VerticalAlignment="Top"
							Margin="20"
							Background="#1A1A1A"
							Padding="10"
							CornerRadius="10">

						<TextBlock x:Name="score_count"
								   Text="Score: 0"
								   Foreground="Gray"
								   FontSize="18"
								   FontWeight="Bold"/>
					</Border>
                </Grid>
            </Grid>
        </Grid>
        <!-- End of main cover grid -->











    </Grid>
</Window>